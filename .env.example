# ----- Public runtime flags -----
NEXT_PUBLIC_SOCIAL_DRY_RUN=true

# ----- Social automation backend -----
SOCIAL_DRY_RUN=true
X_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_SECRET=
