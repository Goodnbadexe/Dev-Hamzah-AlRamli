# =============================================================================
# /subscribe funnel — environment configuration
# =============================================================================
# Copy to .env.local for local dev, or set these in Vercel → Project → Settings
# → Environment Variables for production. The NEXT_PUBLIC_* ones are inlined at
# BUILD time, so after setting them on Vercel you must REDEPLOY for them to apply.

# ── Payment links (one per plan) ─────────────────────────────────────────────
# Paste the checkout URL for each tier (Moyasar / Tap / Stripe Payment Link).
# Moyasar & Tap support Mada + Apple Pay — best for the Saudi audience.
# If a link is left EMPTY, that plan's "GET MY PLAN" button captures the lead and
# shows a "we'll email your plan" confirmation instead of charging (no fake checkout).
NEXT_PUBLIC_CHECKOUT_TRIAL=
NEXT_PUBLIC_CHECKOUT_MONTH=
NEXT_PUBLIC_CHECKOUT_QUARTER=

# ── Lead delivery — set ONE (or both) to receive every quiz lead ─────────────
# Telegram (easiest, free, instant):
#   1) Create a bot with @BotFather → copy the token below.
#   2) Message your new bot once, then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates to read your chat id
#      (or message @userinfobot). Put it in TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OR email the lead via SMTP (uses nodemailer):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_TO=

# ── Supabase — logs every signup to the `leads` table (additive to the above) ─
# SERVER-ONLY. Do NOT prefix with NEXT_PUBLIC — the service-role key bypasses RLS
# and must never reach the browser. Get both from Supabase → Project → Settings →
# API. Apply supabase/migrations/0001_leads.sql first (db push or SQL editor).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Vault — gated PDF delivery (dormant while Gumroad is the store) ───────────
# Secret used to HMAC-sign short-lived download URLs for paid PDFs. Generate a
# long random value (e.g. `openssl rand -hex 32`). Server-only.
VAULT_SIGNING_SECRET=

# ── Gumroad storefront (current payment + delivery) ──────────────────────────
# No per-product env vars: checkout links resolve by CONVENTION from the product
# slug (see gumroadSlug in lib/subscribe/config.ts). Tracks use `<track>-vault-<os>`,
# the bundle uses `all-access-<os>`, all under hamzahramli.gumroad.com. The funnel
# pre-applies LAUNCH50 on single-vault checkout. To add an OS build, just create
# the Gumroad product with its conventional slug — it wires itself, no redeploy
# needed for the link. (Store user + launch code live in config.ts; not secrets.)

# ── Security secrets ──────────────────────────────────────────────────────────
# Shared secret for authenticating webhook calls to /api/webhook/update.
# Generate: openssl rand -hex 32
# Required in production — endpoint returns 503 if not set.
WEBHOOK_SECRET=

# Admin key for gated internal routes (admin/debug/flags pages, social write APIs).
# Generate: openssl rand -hex 32
ADMIN_KEY=

# Set to "true" to block /admin, /debug, /flags, /memory, /lab in non-production
# deployments (preview branches, staging). In production NODE_ENV handles this.
DISABLE_DEV_ROUTES=
