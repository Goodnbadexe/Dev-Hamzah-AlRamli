# =============================================================================
# /subscribe funnel — environment configuration
# =============================================================================
# Copy to .env.local for local dev, or set these in Vercel → Project → Settings
# → Environment Variables for production. The NEXT_PUBLIC_* ones are inlined at
# BUILD time, so after setting them on Vercel you must REDEPLOY for them to apply.

# ── Payment links (one per plan) ─────────────────────────────────────────────
# Paste the checkout URL for each tier (Moyasar / Tap / Stripe Payment Link).
# Moyasar & Tap support Mada + Apple Pay — best for the Saudi audience.
# If a link is left EMPTY, that plan's "GET MY PLAN" button captures the lead and
# shows a "we'll email your plan" confirmation instead of charging (no fake checkout).
NEXT_PUBLIC_CHECKOUT_TRIAL=
NEXT_PUBLIC_CHECKOUT_MONTH=
NEXT_PUBLIC_CHECKOUT_QUARTER=

# ── Lead delivery — set ONE (or both) to receive every quiz lead ─────────────
# Telegram (easiest, free, instant):
#   1) Create a bot with @BotFather → copy the token below.
#   2) Message your new bot once, then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates to read your chat id
#      (or message @userinfobot). Put it in TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OR email the lead via SMTP (uses nodemailer):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_TO=

# ── Supabase — logs every signup to the `leads` table (additive to the above) ─
# SERVER-ONLY. Do NOT prefix with NEXT_PUBLIC — the service-role key bypasses RLS
# and must never reach the browser. Get both from Supabase → Project → Settings →
# API. Apply supabase/migrations/0001_leads.sql first (db push or SQL editor).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Vault — gated PDF delivery (dormant while Gumroad is the store) ───────────
# Secret used to HMAC-sign short-lived download URLs for paid PDFs. Generate a
# long random value (e.g. `openssl rand -hex 32`). Server-only.
VAULT_SIGNING_SECRET=

# ── Gumroad storefront (current payment + delivery) ──────────────────────────
# One product per track + an all-access bundle. Paste each product's Gumroad URL.
# NEXT_PUBLIC_* = inlined at build → redeploy after changing. The quiz recommends
# which product to buy; the "Get my vault" button opens its Gumroad overlay.
# Products are OS-tuned (Windows/Linux/macOS) — set the matching link per OS. The
# quiz captures the buyer's OS and routes them to the right one. The generic
# (no-OS-suffix) var is an optional fallback used until all 18 OS links exist.
NEXT_PUBLIC_GUMROAD_SECURITY=https://hamzahramli.gumroad.com/l/tisljz
NEXT_PUBLIC_GUMROAD_SECURITY_WINDOWS=
NEXT_PUBLIC_GUMROAD_SECURITY_LINUX=
NEXT_PUBLIC_GUMROAD_SECURITY_MACOS=
NEXT_PUBLIC_GUMROAD_DEVELOPERS=
NEXT_PUBLIC_GUMROAD_DEVELOPERS_WINDOWS=
NEXT_PUBLIC_GUMROAD_DEVELOPERS_LINUX=
NEXT_PUBLIC_GUMROAD_DEVELOPERS_MACOS=
NEXT_PUBLIC_GUMROAD_AGENTS=
NEXT_PUBLIC_GUMROAD_AGENTS_WINDOWS=
NEXT_PUBLIC_GUMROAD_AGENTS_LINUX=
NEXT_PUBLIC_GUMROAD_AGENTS_MACOS=
NEXT_PUBLIC_GUMROAD_AUTOMATION=
NEXT_PUBLIC_GUMROAD_AUTOMATION_WINDOWS=
NEXT_PUBLIC_GUMROAD_AUTOMATION_LINUX=
NEXT_PUBLIC_GUMROAD_AUTOMATION_MACOS=
NEXT_PUBLIC_GUMROAD_QUANT=
NEXT_PUBLIC_GUMROAD_QUANT_WINDOWS=
NEXT_PUBLIC_GUMROAD_QUANT_LINUX=
NEXT_PUBLIC_GUMROAD_QUANT_MACOS=
NEXT_PUBLIC_GUMROAD_CREATIVE=
NEXT_PUBLIC_GUMROAD_CREATIVE_WINDOWS=
NEXT_PUBLIC_GUMROAD_CREATIVE_LINUX=
NEXT_PUBLIC_GUMROAD_CREATIVE_MACOS=
NEXT_PUBLIC_GUMROAD_ALL=
NEXT_PUBLIC_GUMROAD_ALL_WINDOWS=
NEXT_PUBLIC_GUMROAD_ALL_LINUX=
NEXT_PUBLIC_GUMROAD_ALL_MACOS=
# Optional fallback used when nothing above is set:
NEXT_PUBLIC_GUMROAD_STORE=

# ── Workflow Tools — standalone one-time pack (30 SAR ≈ $8) ───────────────────
# A single Gumroad product sold at /workflow-tools. Create the product in Gumroad
# (price it so the buyer pays ~30 SAR — see the PR notes on SAR→Gumroad currency),
# then paste its checkout URL here. NEXT_PUBLIC_* = inlined at build → REDEPLOY
# after changing. When empty, the buy button shows "coming soon" (no fake checkout).
NEXT_PUBLIC_GUMROAD_WORKFLOW_TOOLS=
# Server-only. The product's Gumroad permalink/short code (the part after /l/, e.g.
# "wflow" for hamzahramli.gumroad.com/l/wflow). Used to SCOPE entitlement: the
# unlock check only grants access to buyers of THIS product. The existing Gumroad
# Ping webhook already records the sale into `sales` — no new webhook is needed.
# When unset, the unlock gate fails CLOSED (nobody is granted access).
WORKFLOW_TOOLS_PERMALINK=

# ── Gumroad Ping webhook → Supabase `sales` (authoritative entitlement) ───────
# Gumroad → Settings → Advanced → Ping: set the URL to
#   https://www.goodnbad.info/api/gumroad/ping?token=<GUMROAD_PING_TOKEN>
# Ping is UNSIGNED, so this shared secret in the URL is what authenticates it.
# Generate a long random value (e.g. `openssl rand -hex 32`). Server-only.
# Vault downloads are gated on a confirmed, non-refunded row in `sales`, so this
# webhook (plus a one-time backfill of past sales) is REQUIRED for buyers to get
# access. Apply supabase/migrations/0002_sales.sql first (db push or SQL editor).
GUMROAD_PING_TOKEN=

# ── Resend — transactional email (welcome on first charge) ───────────────────
# Server-only. When unset, email is skipped gracefully (the funnel never breaks).
# EMAIL_FROM must be a verified Resend sender, e.g. "Toolkit Vault <vault@goodnbad.info>".
RESEND_API_KEY=
EMAIL_FROM=
